# This file documents what .env.prod contains on the production server.
# It is generated automatically by the CI/CD pipeline — you do NOT need to create it manually.
#
# If you need to deploy manually, copy this to /opt/electronicsprices/.env.prod and fill in ADMIN_API_KEY.

POSTGRES_PASSWORD=Pr1cesDB2024prod
DATABASE_URL=postgresql://postgres:Pr1cesDB2024prod@postgres:5432/electronics_inventory
REDIS_URL=redis://redis:6379/0
ADMIN_API_KEY=<set this as the ADMIN_API_KEY GitHub secret>
NEXT_PUBLIC_API_URL=https://api.prices.cornor.shop
NEXT_PUBLIC_ADMIN_KEY=<same as ADMIN_API_KEY>
IMAGE_TAG=latest
