# Copy this file to .env.prod on the production server and fill in real values.
# This file is read by: docker compose --env-file .env.prod -f docker-compose.prod.yml

# --- Database ---
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/electronics_inventory

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
ADMIN_API_KEY=change-me-production-admin-key

# --- Frontend ---
# Must match the public hostname/IP where the API is reachable from the browser
NEXT_PUBLIC_API_URL=http://api.inventory.local
NEXT_PUBLIC_ADMIN_KEY=change-me-production-admin-key

# --- Deployment (set automatically by CI, override here if deploying manually) ---
IMAGE_TAG=latest
