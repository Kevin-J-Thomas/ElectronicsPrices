# One-time server setup — run these commands on the VPS:
#
#   sudo cp /opt/electronicsprices/nginx/server.conf.example /etc/nginx/sites-available/grattchi.tech
#   sudo ln -s /etc/nginx/sites-available/grattchi.tech /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d grattchi.tech -d www.grattchi.tech -d api.grattchi.tech

server {
    listen 80;
    server_name grattchi.tech www.grattchi.tech api.grattchi.tech;

    location / {
        proxy_pass         http://127.0.0.1:8090;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        'upgrade';
        proxy_read_timeout 60s;
    }
}
